{
  "name": "minty",
  "productName": "Minty",
  "version": "0.1.0",
  "description": "A minimal terminal manager",
  "author": "Minty Contributors",
  "main": "build/main.js",
  "scripts": {
    "build": "bun build.ts",
    "dev": "bun run build && electron .",
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-rebuild -f -w node-pty",
    "package:mac": "bun run build && electron-builder --mac zip"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.3.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/node": "^20.0.0",
    "electron": "^29.4.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.0"
  },
  "build": {
    "appId": "com.minty.app",
    "productName": "Minty",
    "directories": {
      "output": "release"
    },
    "files": [
      "build/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/minty.icns",
      "target": [
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    }
  }
}
